COMPOSE_PROJECT_NAME=ukrflybud-manager

APP_NAME=UKRFLYBUD Manager API
APP_ENV=local
APP_LOCALE=uk-UA
APP_TIMEZONE=Europe/Kyiv
# CORS_ORIGINS supports a JSON array or a comma-separated string.
# Example JSON: ["http://localhost:5173","http://localhost:8000"]
# Example CSV: http://localhost:5173,http://localhost:8000
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
LOG_LEVEL=INFO
LOGGING_CONFIG_PATH=logging.yaml
AUTH_SECRET_KEY=change-this-local-development-secret
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_LOCK_MINUTES=15
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Адміністратор
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe12345

POSTGRES_DB=ukrflybud
POSTGRES_USER=ukrflybud
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ukrflybud:change-me@postgres:5432/ukrflybud

BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=8080

VITE_API_BASE_URL=/api
VITE_DEFAULT_LOCALE=uk-UA
VITE_TIMEZONE=Europe/Kyiv

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@ukrflybud.example.com
PGADMIN_DEFAULT_PASSWORD=change-me
