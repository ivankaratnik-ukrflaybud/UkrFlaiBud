{
  "name": "ukrflybud-manager-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier .. --write --config ../.prettierrc.json --ignore-path ../.prettierignore",
    "format:check": "prettier .. --check --config ../.prettierrc.json --ignore-path ../.prettierignore",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@emotion/react": ">=11.14.0 <12.0.0",
    "@emotion/styled": ">=11.14.0 <12.0.0",
    "@hookform/resolvers": ">=3.10.0 <6.0.0",
    "@mui/icons-material": ">=6.4.0 <8.0.0",
    "@mui/material": ">=6.4.0 <8.0.0",
    "@tanstack/react-query": ">=5.62.0 <6.0.0",
    "dayjs": ">=1.11.13 <2.0.0",
    "i18next": ">=24.2.0 <26.0.0",
    "react": ">=19.0.0 <20.0.0",
    "react-dom": ">=19.0.0 <20.0.0",
    "react-hook-form": ">=7.54.0 <8.0.0",
    "react-i18next": ">=15.4.0 <17.0.0",
    "react-router-dom": ">=7.1.0 <8.0.0",
    "zod": ">=3.24.0 <5.0.0"
  },
  "devDependencies": {
    "@eslint/js": ">=9.17.0 <10.0.0",
    "@testing-library/jest-dom": ">=6.6.0 <7.0.0",
    "@testing-library/react": ">=16.2.0 <17.0.0",
    "@testing-library/user-event": ">=14.6.0 <15.0.0",
    "@vitejs/plugin-react": ">=4.3.0 <6.0.0",
    "@types/react": ">=19.0.0 <20.0.0",
    "@types/react-dom": ">=19.0.0 <20.0.0",
    "eslint": ">=9.17.0 <10.0.0",
    "eslint-plugin-react-hooks": ">=5.1.0 <6.0.0",
    "eslint-plugin-react-refresh": ">=0.4.16 <1.0.0",
    "globals": ">=15.14.0 <17.0.0",
    "jsdom": ">=26.0.0 <28.0.0",
    "prettier": ">=3.4.0 <4.0.0",
    "typescript": ">=5.7.0 <6.0.0",
    "typescript-eslint": ">=8.18.0 <9.0.0",
    "vite": ">=6.0.0 <8.0.0",
    "vitest": ">=3.0.0 <4.0.0"
  }
}
